# OADP Upload Integration Test Configuration
# Copy this file to .env and fill in the values.
#
# AWS Configuration (required for S3 tests)
ETCD_UPLOAD_TEST_AWS_BUCKET=
ETCD_UPLOAD_TEST_AWS_REGION=
ETCD_UPLOAD_TEST_AWS_CREDENTIALS_FILE=

# Azure Configuration (required for Azure Blob tests)
ETCD_UPLOAD_TEST_AZURE_STORAGE_ACCOUNT=
ETCD_UPLOAD_TEST_AZURE_CONTAINER=
ETCD_UPLOAD_TEST_AZURE_RESOURCE_GROUP=
ETCD_UPLOAD_TEST_AZURE_SUBSCRIPTION_ID=
