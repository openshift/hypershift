# Build stage
FROM registry.ci.openshift.org/openshift/release:rhel-9-release-golang-1.25-openshift-4.22 AS builder
WORKDIR /build
COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o dashboard ./cmd/dashboard
RUN CGO_ENABLED=1 GOOS=linux go build -o scraper ./cmd/scraper
RUN GOFLAGS='' go install github.com/fzipp/gocyclo/cmd/gocyclo@v0.6.0
RUN GOFLAGS='' go install github.com/uudashr/gocognit/cmd/gocognit@v1.1.3

# Runtime stage
FROM registry.access.redhat.com/ubi9-minimal:latest
RUN microdnf install -y --setopt=install_weak_deps=0 \
      --disablerepo='*' --enablerepo='ubi-9-baseos-rpms' --enablerepo='ubi-9-appstream-rpms' \
      git-core sqlite && \
    microdnf clean all && \
    rm -rf /var/cache/yum
COPY --from=builder /build/dashboard /usr/local/bin/dashboard
COPY --from=builder /build/scraper /usr/local/bin/scraper
COPY --from=builder /go/bin/gocyclo /usr/local/bin/gocyclo
COPY --from=builder /go/bin/gocognit /usr/local/bin/gocognit
COPY web/ /opt/dashboard/web/

RUN mkdir -p /data && chown 1001:0 /data && chmod 775 /data
USER 1001
WORKDIR /opt/dashboard
