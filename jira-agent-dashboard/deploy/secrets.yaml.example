# EXAMPLE — do NOT commit real credentials.
# Copy this file to secrets.yaml, fill in values, and apply manually:
#   cp secrets.yaml.example secrets.yaml
#   # edit secrets.yaml with real values
#   kubectl apply -f secrets.yaml
#
# Generate the proxy session secret:
#   openssl rand -base64 32 > /tmp/session_secret
#   kubectl -n jira-agent-dashboard create secret generic dashboard-proxy-session \
#     --from-file=session_secret=/tmp/session_secret
#   rm /tmp/session_secret
---
apiVersion: v1
kind: Secret
metadata:
  name: dashboard-secrets
  namespace: jira-agent-dashboard
type: Opaque
stringData:
  GITHUB_APP_ID: "<your-github-app-id>"
  GITHUB_APP_INSTALLATION_ID: "<your-github-app-installation-id>"
---
apiVersion: v1
kind: Secret
metadata:
  name: github-app-key
  namespace: jira-agent-dashboard
type: Opaque
data:
  # base64 -i /path/to/your-app.private-key.pem
  private-key.pem: "<base64-encoded-private-key>"
