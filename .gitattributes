# Mark autogenerated files so GitHub collapses them in PR diffs
# and excludes them from repo language statistics.

# Generated deepcopy, defaults, conversion, and CRD manifests
**/zz_generated.* linguist-generated=true
cmd/install/assets/hypershift-operator/*.crd.yaml linguist-generated=true

# Generated client code (applyconfiguration, clientset, informers, listers)
client/** linguist-generated=true

# Generated API reference docs
docs/content/reference/api.md linguist-generated=true
docs/content/reference/aggregated-docs.md linguist-generated=true

# Test fixtures
**/testdata/** linguist-generated=true

# Vendored dependencies
vendor/** linguist-vendored=true
api/vendor/** linguist-vendored=true
hack/tools/vendor/** linguist-vendored=true
